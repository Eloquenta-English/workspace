<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>Our Teachers — Articulate English</title>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700;800;900&family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
:root{--bg:#0a0e1a;--bg2:#0d1117;--bg3:#111827;--bg-card:#111827;--bg-card2:#0f1629;--border:#1e3a5f;--border-light:#2a4a7f;--text:#e0f2fe;--text-muted:#94a3b8;--text-dim:#4a6080;--accent:#f59e0b;--accent2:#dc2626;--accent-dim:rgba(245,158,11,.08);--accent-glow:rgba(245,158,11,.35);--green:#34d399;--amber:#fbbf24;--violet:#a78bfa;--rose:#fb7185;}
*{margin:0;padding:0;box-sizing:border-box}
html{font-size:16px;scroll-behavior:smooth}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);line-height:1.6;overflow-x:hidden}
.nav{position:sticky;top:0;z-index:50;background:rgba(10,14,26,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--border);padding:0 40px;height:56px;display:flex;align-items:center;justify-content:space-between}
.nav-logo{font-family:'Space Grotesk',sans-serif;font-size:1.2rem;font-weight:700;color:var(--text);letter-spacing:2px;text-decoration:none}
.nav-logo span{color:var(--accent)}
.nav-links{display:flex;gap:24px;align-items:center}
.nav-links a{color:var(--text-muted);text-decoration:none;font-size:.85rem;font-weight:500;transition:color .15s}
.nav-links a:hover{color:var(--text)}
.nav-cta{padding:8px 20px;border-radius:8px;background:var(--accent);color:#000;text-decoration:none;font-size:.8rem;font-weight:700;transition:all .15s;white-space:nowrap}
.nav-cta:hover{background:var(--amber);box-shadow:0 0 16px var(--accent-glow)}
.footer{padding:40px;text-align:center;font-size:.75rem;color:var(--text-dim);border-top:1px solid var(--border)}
.footer-links{display:flex;justify-content:center;gap:24px;margin-bottom:16px;flex-wrap:wrap}
.footer-links a{color:var(--text-muted);text-decoration:none;transition:color .15s}
.footer-links a:hover{color:var(--text)}
.hero{padding:60px 40px 40px;text-align:center;max-width:760px;margin:0 auto}
.hero h1{font-family:'Space Grotesk',sans-serif;font-size:2.8rem;font-weight:800;line-height:1.1;margin-bottom:12px;color:var(--text)}
.hero h1 .accent{color:var(--accent)}
.hero p{font-size:1.05rem;color:var(--text-muted);line-height:1.7}
.section{padding:60px 40px;max-width:1100px;margin:0 auto}
.section-header{text-align:center;margin-bottom:48px}
.section-header h2{font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:700;margin-bottom:12px}
.section-header p{color:var(--text-muted);font-size:1rem;max-width:560px;margin:0 auto;line-height:1.7}
.section-num{font-size:.7rem;font-weight:700;color:var(--accent);letter-spacing:3px;text-transform:uppercase;margin-bottom:8px}
.diff-grid{display:grid;grid-template-columns:repeat(2,1fr);gap:20px}
.diff-card{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;display:flex;gap:16px;transition:all .2s}
.diff-card:hover{border-color:var(--border-light);box-shadow:0 8px 30px rgba(0,0,0,.2)}
.diff-num{font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:900;color:var(--accent);opacity:.3;flex-shrink:0;width:40px;line-height:1}
.diff-content h3{font-family:'Space Grotesk',sans-serif;font-size:.95rem;font-weight:700;margin-bottom:6px}
.diff-content p{font-size:.8rem;color:var(--text-muted);line-height:1.7}
.cta-section{padding:60px 40px;text-align:center;background:var(--bg2);border-top:1px solid var(--border)}
.cta-section h2{font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:700;margin-bottom:12px}
.cta-section p{color:var(--text-muted);margin-bottom:28px;font-size:1rem;max-width:500px;margin-left:auto;margin-right:auto}
.cta-buttons{display:flex;gap:12px;justify-content:center;flex-wrap:wrap}
.cta-primary{padding:12px 28px;border-radius:10px;background:var(--accent);color:#000;text-decoration:none;font-size:.9rem;font-weight:700;transition:all .2s}
.cta-primary:hover{background:var(--amber);box-shadow:0 0 20px var(--accent-glow)}
.cta-secondary{padding:12px 28px;border-radius:10px;border:1px solid var(--border);color:var(--text-muted);text-decoration:none;font-size:.9rem;font-weight:600;transition:all .15s}
.cta-secondary:hover{border-color:var(--text-muted);color:var(--text)}
.form-group{margin-bottom:16px}
.form-group label{display:block;font-size:.75rem;font-weight:600;color:var(--text-muted);margin-bottom:6px;font-family:'Space Grotesk',sans-serif;letter-spacing:.5px}
.form-group input,.form-group select,.form-group textarea{width:100%;padding:12px 16px;border-radius:8px;border:1px solid var(--border);background:var(--bg);color:var(--text);font-size:.9rem;font-family:inherit;outline:none;transition:border-color .15s}
.form-group input:focus,.form-group select:focus,.form-group textarea:focus{border-color:var(--accent)}
.form-group textarea{resize:none;height:100px}
.auth-btn{width:100%;padding:14px;border-radius:10px;background:var(--accent);color:#000;border:none;font-size:.9rem;font-weight:700;cursor:pointer;transition:all .2s;font-family:'Space Grotesk',sans-serif}
.auth-btn:hover{background:var(--amber);box-shadow:0 0 16px var(--accent-glow)}
.grid-2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.grid-3{display:grid;grid-template-columns:repeat(3,1fr);gap:16px}
.stat-card{background:var(--bg-card);border:1px solid var(--border);border-radius:14px;padding:24px;text-align:center}
.stat-card .num{font-family:'Space Grotesk',sans-serif;font-size:2rem;font-weight:900;color:var(--accent)}
.stat-card .label{font-size:.7rem;color:var(--text-dim);text-transform:uppercase;letter-spacing:1px;margin-top:4px}
@media(max-width:900px){.diff-grid{grid-template-columns:1fr}.grid-2,.grid-3{grid-template-columns:1fr}.hero h1{font-size:2rem}.nav{padding:0 20px}.hero,.section,.cta-section{padding-left:20px;padding-right:20px}}
@media(max-width:520px){.hero h1{font-size:1.6rem}.nav-links{display:none}}
</style>
</head>
<body><div class="nav">
  <a href="../index.html" class="nav-logo">ARTICULATE <span>ENGLISH</span></a>
  <div class="nav-links">
    <a href="index.html">Teachers</a>
    <a href="../pricing/index.html">Pricing</a>
    <a href="../login.html">Login</a>
    <a href="become-a-teacher.html" class="nav-cta">Apply to Teach</a>
  </div>
</div><div class="hero"><h1>Find Your <span class="accent">Teacher</span></h1><p>Every teacher is certified, vetted, and continuously trained. Filter by language, specialty, and price.</p></div><div class="section"><div style="display:flex;gap:12px;margin-bottom:32px;flex-wrap:wrap;justify-content:center"><button class="btn-filter" style="background:var(--accent);color:#000;border-color:var(--accent)" onclick="document.querySelectorAll('.btn-filter').forEach(function(b){b.style.background='var(--bg)';b.style.color='var(--text-muted)';b.style.borderColor='var(--border)';});this.style.background='var(--accent)';this.style.color='#000';this.style.borderColor='var(--accent)';">All Teachers</button><button class="btn-filter"  onclick="document.querySelectorAll('.btn-filter').forEach(function(b){b.style.background='var(--bg)';b.style.color='var(--text-muted)';b.style.borderColor='var(--border)';});this.style.background='var(--accent)';this.style.color='#000';this.style.borderColor='var(--accent)';">General English</button><button class="btn-filter"  onclick="document.querySelectorAll('.btn-filter').forEach(function(b){b.style.background='var(--bg)';b.style.color='var(--text-muted)';b.style.borderColor='var(--border)';});this.style.background='var(--accent)';this.style.color='#000';this.style.borderColor='var(--accent)';">Exam Prep</button><button class="btn-filter"  onclick="document.querySelectorAll('.btn-filter').forEach(function(b){b.style.background='var(--bg)';b.style.color='var(--text-muted)';b.style.borderColor='var(--border)';});this.style.background='var(--accent)';this.style.color='#000';this.style.borderColor='var(--accent)';">Business English</button><button class="btn-filter"  onclick="document.querySelectorAll('.btn-filter').forEach(function(b){b.style.background='var(--bg)';b.style.color='var(--text-muted)';b.style.borderColor='var(--border)';});this.style.background='var(--accent)';this.style.color='#000';this.style.borderColor='var(--accent)';">Accent Coaching</button><button class="btn-filter"  onclick="document.querySelectorAll('.btn-filter').forEach(function(b){b.style.background='var(--bg)';b.style.color='var(--text-muted)';b.style.borderColor='var(--border)';});this.style.background='var(--accent)';this.style.color='#000';this.style.borderColor='var(--accent)';">Young Learners</button></div><div class="grid-3" style="gap:20px"><div class="diff-card" style="flex-direction:column;text-align:center">
<div style="width:56px;height:56px;border-radius:50%;background:var(--accent-dim);margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-family:'Space Grotesk',sans-serif;font-size:1.1rem;font-weight:700;color:var(--accent)">SM</div>
<h3 style="font-family:'Space Grotesk',sans-serif;font-size:.95rem;font-weight:700;margin-bottom:4px">Sarah M.</h3>
