<div style="width:56px;height:56px;border-radius:50%;background:var(--accent-dim);margin:0 auto 12px;display:flex;align-items:center;justify-content:center;font-family:'Space Grotesk',sans-serif;font-size:1.1rem;font-weight:700;color:var(--accent)">MR</div>
