# PayFast Configuration
# Get these from your PayFast dashboard → Settings → Integration
PAYFAST_MERCHANT_ID=your_merchant_id_here
PAYFAST_MERCHANT_KEY=your_merchant_key_here
PAYFAST_PASSPHRASE=your_passphrase_here

# Use sandbox for testing, live for production
# SANDBOX: https://sandbox.payfast.co.za/eng/process
# LIVE:    https://www.payfast.co.za/eng/process
PAYFAST_BASE_URL=https://sandbox.payfast.co.za/eng/process

# Admin panel password — CHANGE THIS
ADMIN_PASSWORD=change-this-to-something-secure

# Server port (default 3000)
PORT=3000
