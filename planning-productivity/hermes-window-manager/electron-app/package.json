{
  "name": "hermes-window-manager",
  "version": "1.0.0",
  "description": "Hermes Window Manager - Dock your Hermes console windows into minimisable lanes",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0"
  },
  "dependencies": {
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "node-pty": "^1.0.0"
  },
  "build": {
    "appId": "com.williamthomason.hermes-window-manager",
    "productName": "Hermes Window Manager",
    "win": {
      "target": "portable",
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*",
      "node_modules/**/*"
    ]
  }
}
